# Local PostgreSQL connection used by the Express API, db:seed, db:bridge,
# and src/server/db.js. Defaults to this value in code if omitted.
DATABASE_URL="postgres://postgres@localhost:5432/logisticplus"

# Maintenance database used only by db:seed to create DATABASE_URL's database.
# The connected user must be allowed to create the target database.
POSTGRES_ADMIN_URL="postgres://postgres@localhost:5432/postgres"

# Password assigned to the seeded owner user by db:seed.
# Use a real secret outside local development. If omitted, db:seed falls back
# to the local-only default password documented in README.md.
SEED_USER_PASSWORD="CHANGE_ME"

# Fresh production bootstrap for `npm run seed:production-admin`.
# Set real values only in Liara or your local shell; never commit them.
INITIAL_ADMIN_EMAIL=""
INITIAL_ADMIN_PASSWORD=""
INITIAL_ADMIN_NAME=""
INITIAL_ORG_NAME=""
INITIAL_ADMIN_PHONE=""
INITIAL_ORG_PLAN_ID="enterprise"
INITIAL_ORG_BILLING_CYCLE="annual"
INITIAL_ORG_SUBSCRIPTION_STATUS="active"

# Optional seed identifiers used by db:bridge.
SEED_USER_ID="u1"
SEED_ORGANIZATION_ID="org-logisticplus-default"

# Public base URL for generated links and payment callbacks.
# Production should use the real public HTTPS origin.
APP_PUBLIC_URL="http://localhost:3000"

# Strong secret for signed public document links. Required in production.
SESSION_SECRET=""

# Optional cookie domain for custom-domain deployments. Leave blank for Liara
# default domains unless you intentionally need cross-subdomain cookies.
COOKIE_DOMAIN=""

# Runtime HTTP port. Defaults to 3000.
PORT="3000"

# Local document upload storage. The current app stores files on disk.
# In Liara production, mount a persistent disk to this same path.
DOCUMENT_STORAGE_DIR="storage/documents"

# Maximum upload size in bytes. The server defaults to 25 MiB.
DOCUMENT_MAX_BYTES="26214400"

# Document storage mode. Fresh production should use S3-compatible object
# storage. For ArvanCloud, use an endpoint like:
# https://s3.<ARVAN_REGION>.arvanstorage.ir
# Example region: ir-thr-at1. Keep S3_FORCE_PATH_STYLE=true for this custom
# endpoint unless ArvanCloud support tells you otherwise.
# Keep local defaults for development unless object storage is being tested.
DOCUMENT_STORAGE_MODE="local"
OBJECT_STORAGE_ENABLED="false"
OBJECT_STORAGE_PROVIDER="s3"
S3_ENDPOINT="https://s3.<ARVAN_REGION>.arvanstorage.ir"
S3_REGION="<ARVAN_REGION>"
S3_ACCESS_KEY_ID="<ARVAN_ACCESS_KEY_ID>"
S3_SECRET_ACCESS_KEY="<ARVAN_SECRET_ACCESS_KEY>"
S3_DOCUMENT_BUCKET="<ARVAN_BUCKET_NAME>"
S3_FORCE_PATH_STYLE="true"
DOCUMENT_STORAGE_DUAL_WRITE_REQUIRED="false"

# Test-only object storage provider. Use with OBJECT_STORAGE_PROVIDER=local-mock
# for Playwright/script verification without live S3-compatible credentials.
OBJECT_STORAGE_MOCK_DIR="storage/test-object-documents"

# Zarinpal payment configuration. Sandbox behavior is used unless this is
# explicitly set to "false"; a real merchant id is required for production
# payment requests.
ZARINPAL_SANDBOX="true"
ZARINPAL_MERCHANT_ID=""
ZARINPAL_TIMEOUT_MS="10000"

# SMS.ir alerts. Keep dry-run enabled until provider credentials and templates
# are verified. The background worker is opt-in; platform admin can also run it
# manually from the admin panel.
SMS_ENABLED="false"
SMS_DRY_RUN="true"
SMSIR_API_KEY=""
SMSIR_LINE_NUMBER=""
SMSIR_USE_DEFAULT_LINE="false"
SMS_TIMEOUT_MS="10000"
SMS_WORKER_ENABLED="false"
SMS_WORKER_INTERVAL_MS="300000"

# Guarded production SMS smoke settings. Leave blank unless you are running
# `npm run sms:prod-smoke` against Liara production with live credentials.
SMS_SMOKE_OWNER_EMAIL="darksudo22@gmail.com"
SMS_SMOKE_TARGET_PHONE=""
SMS_SMOKE_ALLOW_CURRENT_KEY="false"

# Rate-limit backing store. Defaults to memory in development and postgres in
# production. Use postgres on Liara so limits are shared across instances.
RATE_LIMIT_STORE="memory"

# Trust the platform reverse proxy for req.ip and generated HTTPS links.
# Defaults to true in production and false in development if omitted.
TRUST_PROXY="false"

# Set to true to disable Vite hot module replacement during assisted editing.
DISABLE_HMR="false"

# Set to "production" only when running the production server build. In
# production, server.js serves dist/ and marks session cookies Secure.
NODE_ENV="development"

# Playwright e2e security test settings. The test database name must include
# "test"; reset-test-db refuses to reset any other database name.
TEST_DATABASE_URL="postgres://postgres@localhost:5432/logisticplus_test"
TEST_PORT="3010"
TEST_SEED_USER_PASSWORD="playwright-owner-pass"
TEST_DOCUMENT_STORAGE_DIR="storage/test-documents"

# Optional fallback when Playwright browser downloads are unavailable.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

# Liara staging validation smoke settings. These are used only by
# `npm run smoke:staging` after a staging deploy.
STAGING_PUBLIC_URL=""
STAGING_OWNER_EMAIL="darksudo22@gmail.com"
STAGING_OWNER_PASSWORD=""
STAGING_SMOKE_SHIPMENT_ID="s1"
STAGING_SKIP_AUTH_SMOKE="false"
STAGING_SKIP_ZARINPAL_HANDOFF="false"
STAGING_ALLOW_INSECURE_URL="false"
