{
  "name": "logisticplus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.js",
    "build": "vite build",
    "start": "node server.js",
    "preview": "vite preview",
    "db:schema": "tsx scripts/apply-schema.ts",
    "db:migrate": "tsx scripts/migrate.ts up",
    "db:migrate:status": "tsx scripts/migrate.ts status",
    "db:migrate:baseline": "tsx scripts/migrate.ts baseline",
    "db:migrate:fresh:test": "tsx scripts/verify-migrations.ts fresh",
    "db:migrate:current:test": "tsx scripts/verify-migrations.ts current-schema",
    "db:seed": "tsx scripts/seed-db.ts",
    "seed:production-core": "tsx scripts/seed-production-core.ts",
    "seed:production-core:test": "tsx scripts/verify-production-core-seed.ts",
    "seed:production-admin": "tsx scripts/seed-production-admin.ts",
    "seed:production-admin:test": "tsx scripts/verify-production-admin-bootstrap.ts",
    "verify:fresh-production": "tsx scripts/verify-fresh-production.ts",
    "db:seed:demo": "tsx scripts/seed-demo-company.ts",
    "db:bridge": "tsx scripts/bridge-canonical-db.ts",
    "documents:storage:backfill": "tsx scripts/backfill-document-storage.ts",
    "documents:storage:verify": "tsx scripts/verify-document-storage.ts",
    "documents:storage:smoke": "tsx scripts/smoke-document-storage.ts",
    "test:e2e:setup": "tsx scripts/reset-test-db.ts",
    "test:e2e": "playwright test",
    "test:search": "playwright test tests/e2e/search.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "qa:seed-heavy": "tsx scripts/qa-seed-heavy.ts",
    "qa:create-session": "tsx scripts/qa-create-session.ts",
    "qa:load": "tsx scripts/qa-load.ts",
    "qa:cleanup-prod": "tsx scripts/qa-cleanup-prod.ts",
    "qa:repair-shipments": "tsx scripts/qa-repair-shipments.ts",
    "billing:sync-plans": "tsx scripts/billing-sync-plans.ts",
    "smoke:production-config": "tsx scripts/smoke-production-config.ts",
    "smoke:staging": "tsx scripts/validate-liara-staging.ts",
    "safety:check": "node scripts/safety-check.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "audit:dead": "knip --production",
    "audit:deps": "depcheck",
    "deploy": "liara deploy",
    "deploy:staging": "liara deploy --liara-json liara.staging.json --app logisticplus-staging --port 3000 --disks logisticplus-documents-staging:storage/documents"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns-jalali": "^4.1.0-0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@liara/cli": "^9.4.7",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "depcheck": "^1.4.7",
    "knip": "^6.17.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
